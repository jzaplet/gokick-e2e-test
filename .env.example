APP_HTTP_PORT=3000
APP_DB_PATH=./data/app.db
# WAL is the default. Switch to DELETE when the same DB is read by another
# process via a Docker bind mount (e.g. PhpStorm browsing data/app.db while
# the container writes to it) — Docker Desktop's virtualised FS doesn't
# guarantee mmap/shm coordination that WAL requires.
APP_DB_JOURNAL_MODE=DELETE
APP_JWT_SECRET=change-me-to-at-least-32-characters-long-secret
APP_JWT_ACCESS_EXPIRATION=15m
APP_JWT_REFRESH_EXPIRATION=168h
APP_CORS_ORIGIN=http://localhost:5173
APP_COOKIE_SECURE=false

# Structured logging. Format: json (default, for aggregators like Loki) or
# text (human-readable, handy for local `make serve`). Level: debug, info
# (default), warn, error. Unknown values fall back to json / info.
APP_LOG_FORMAT=json
APP_LOG_LEVEL=info

# Required only when running `./bin/app seed`. Pick a strong password (8-128
# chars). Leave empty in environments where the seed command is never run.
APP_SEED_ADMIN_PASSWORD=

# Set to true only when running behind a reverse proxy you trust to
# rewrite X-Real-IP. With this off (default), per-IP rate limiting uses
# RemoteAddr — safe but means everyone behind the proxy shares a bucket.
APP_TRUST_PROXY_HEADERS=false

# Per-IP token-bucket caps for auth endpoints. Format: N/sec, N/min,
# N/hour, or N/Xs|m|h. Set empty to disable.
APP_RATE_LIMIT_LOGIN=10/min
APP_RATE_LIMIT_REFRESH=60/min

# Sentry error & panic tracking. Empty DSN = disabled (the app runs unchanged
# and ships no telemetry). Backend and frontend are separate Sentry projects,
# hence two DSNs. APP_* is read by the Go binary; VITE_* is baked into the SPA
# bundle at build time (a Sentry DSN is public — safe to embed).
APP_SENTRY_DSN=
APP_SENTRY_ENVIRONMENT=development
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development
# The release version is set automatically at build time from the git tag
# (Makefile / production Dockerfile / release workflow → main.release +
# VITE_SENTRY_RELEASE), so you normally don't set these. Override only to pin a
# release manually for a build that isn't tag-stamped.
# APP_SENTRY_RELEASE=
# VITE_SENTRY_RELEASE=

DOCUMAN_HTTP_PORT=3005